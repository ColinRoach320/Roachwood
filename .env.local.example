# Public — safe to expose in the browser bundle
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — bypasses RLS. NEVER ship to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — used for invoice payment links + webhook signature verification.
# Required to send/pay invoices; the rest of the app works without it.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Public site origin (used by Stripe success/cancel redirects). Optional —
# falls back to NEXT_PUBLIC_APP_URL or http://localhost:3000.
NEXT_PUBLIC_APP_URL=http://localhost:3000
